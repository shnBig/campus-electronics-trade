<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.electronics.managerservice.mapper.ManagerMapper">

    <select id="selectByUserName" resultType="com.electronics.commonserver.entity.Manager">
        SELECT * FROM user
        WHERE user_name = #{username}
    </select>

    <select id="selectRolesByUserId" resultType="java.lang.String">
        SELECT r.role_name
        FROM user_role ur
        JOIN role r ON ur.role_id = r.id
        WHERE ur.user_id = #{userId}
    </select>
</mapper>
